-# locals:
-#   f           — a bootstrap_form builder scoped to the resource (work/collection/community)
-#   descriptive — Hash from Metadata::MODSFields (bare title, structured parts, abstract, keywords)
-#   keywords    — Boolean: show the (mandatory) Keywords field (Works only)
-#
-# The Title field edits only the bare primary <mods:title>; structured parts
-# (subtitle / part name / part number / non-sort) are shown read-only and edited
-# via the XML editor, so saving here never flattens a curated title.
- parts = { 'Subtitle' => descriptive[:subtitle], 'Part name' => descriptive[:part_name], 'Part number' => descriptive[:part_number], 'Non-sort' => descriptive[:non_sort] }.compact
- parts_note_id = 'title-parts-note' if parts.any?

= f.text_field :title, value: descriptive[:title], required: true, label: 'Title', aria: ({ describedby: parts_note_id } if parts_note_id)

- if parts.any?
  -# Quiet read-only caption (not a .well — wells are for form-section/action
  -# blocks). Plain prose values: these are title fragments, not identifiers, so
  -# no monospace treatment (per the institutional register).
  .form-text.text-muted.small.mb-3{ id: parts_note_id }
    %i.fa-solid.fa-circle-info{'aria-hidden' => 'true'}
    Additional title parts (edit via the XML tab to keep them intact):
    %ul.mb-0
      - parts.each do |label, value|
        %li
          %strong= "#{label}:"
          = value

= f.text_area :description, rows: 10, value: descriptive[:abstract], label: 'Description'

- if keywords
  -# Stacked-input keyword editor (keyword-list Stimulus controller): each
  -# committed keyword is a row with a red "−"; the final entry row's green "+"
  -# (or Enter) promotes the typed value into a row. Every input posts as
  -# `<resource>[keywords][]`, so a value typed-but-not-added is still saved; the
  -# server strips/dedupes. At least one keyword is required (descriptive_valid?).
  .mb-3{ data: { controller: 'keyword-list' } }
    %label.form-label.mb-1 Keywords
    - Array(descriptive[:keywords]).each do |kw|
      .input-group.mb-2{ data: { 'keyword-list-target': 'row' } }
        %input.form-control{ type: 'text', name: "#{f.object_name}[keywords][]", value: kw, 'aria-label': 'Keyword' }
        %button.btn.btn-danger{ type: 'button', 'aria-label': 'Remove keyword', data: { action: 'click->keyword-list#remove' } }
          %i.fa-solid.fa-minus{ 'aria-hidden': 'true' }
    %template{ data: { 'keyword-list-target': 'template' } }
      .input-group.mb-2
        %input.form-control{ type: 'text', name: "#{f.object_name}[keywords][]", 'aria-label': 'Keyword' }
        %button.btn.btn-danger{ type: 'button', 'aria-label': 'Remove keyword', data: { action: 'click->keyword-list#remove' } }
          %i.fa-solid.fa-minus{ 'aria-hidden': 'true' }
    .input-group.mb-1
      %input.form-control{ type: 'text', name: "#{f.object_name}[keywords][]", placeholder: 'Add a keyword…', 'aria-label': 'Add a keyword', data: { 'keyword-list-target': 'entry', action: 'keydown->keyword-list#addOnEnter' } }
      %button.btn.btn-success{ type: 'button', 'aria-label': 'Add keyword', data: { action: 'click->keyword-list#add' } }
        %i.fa-solid.fa-plus{ 'aria-hidden': 'true' }
    .form-text.text-muted Press + (or Enter) to add a keyword. At least one is required.
