-if !@thumbs.nil? && @thumbs.length > 0
  %picture
    %source{media: "(max-width: 980px)", srcset: "#{@thumbs[0]}", width: "85px"}
    %source{media: "(min-width: 981px) and (max-width: 1199px)", srcset: "#{@thumbs[1]}, #{@thumbs[2]} 2x", width: "135px"}
    %source{media: "(min-width: 1200px)", srcset: "#{@thumbs[1]}, #{@thumbs[2]} 2x", width: "170px"}
    %img{src: "data:image/gif;base64,R0lGODlhAQABAIAAAP///wAAACwAAAAAAQABAAACAkQBADs=", loading: "lazy", width: "170", height: "170"}/