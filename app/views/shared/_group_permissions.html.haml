-# locals: resource (String) — e.g. 'work', 'collection', 'community'
-#
-# Host view sets the Stimulus scope on a wrapper:
-#   data-controller="group-permissions" data-group-permissions-resource-value="<resource>"
-#
-# Stacked-input pattern (mirrors the keyword editor): each committed grant is a
-# row with a red "−"; the final entry row's green "+" promotes the selected
-# group + ability into a new committed row. The entry row also submits (index
-# "new"), so a selection made but not "+"-ed is not lost; blank entries are
-# skipped server-side (form_group_permissions ignores rows without a group_id).
%h5.pb-2 Group Permissions
- @permissions.each.with_index(1) do |group, index|
  .row.py-1{ id: "group-list_#{index}", data: { "group-permissions-target": "row" } }
    .col-sm-auto.form-text Group
    .col-sm
      %select.form-select.form-select-sm.groups{ "aria-label" => "Group", name: "#{resource}[permissions][#{index}][group_id]" }
        %option{ value: group[0], selected: "selected" } #{group[1]}
        - @groups.each do |user_group|
          - unless user_group[0] == group[0]
            %option{ value: user_group[0] } #{user_group[1]}
    .col-sm-auto.form-text Ability
    .col-sm-2
      %select.form-select.form-select-sm.ability{ "aria-label" => "Ability", name: "#{resource}[permissions][#{index}][ability]" }
        %option{ value: "read", selected: group[2] == "View" } View
        %option{ value: "edit", selected: group[2] == "Manage" } Manage
    .col-sm-2
      %button.btn.btn-danger.form-control.btn-sm{ type: "button", "aria-label" => "Remove group", data: { action: "click->group-permissions#remove" } }
        %i.fa-solid.fa-minus{ "aria-hidden" => "true" }

%template{ data: { "group-permissions-target": "template" } }
  .row.py-1
    .col-sm-auto.form-text Group
    .col-sm
      %select.form-select.form-select-sm.groups{ "aria-label" => "Group" }
        %option{ value: "" }
        - @groups.each do |user_group|
          %option{ value: user_group[0] } #{user_group[1]}
    .col-sm-auto.form-text Ability
    .col-sm-2
      %select.form-select.form-select-sm.ability{ "aria-label" => "Ability" }
        %option{ value: "read" } View
        %option{ value: "edit" } Manage
    .col-sm-2
      %button.btn.btn-danger.form-control.btn-sm{ type: "button", "aria-label" => "Remove group", data: { action: "click->group-permissions#remove" } }
        %i.fa-solid.fa-minus{ "aria-hidden" => "true" }

.row.py-1{ data: { "group-permissions-target": "entry" } }
  .col-sm-auto.form-text Group
  .col-sm
    %select.form-select.form-select-sm.groups{ "aria-label" => "Add group", name: "#{resource}[permissions][new][group_id]", data: { "group-permissions-target": "entryGroup" } }
      %option{ value: "" } Select a group…
      - @groups.each do |user_group|
        %option{ value: user_group[0] } #{user_group[1]}
  .col-sm-auto.form-text Ability
  .col-sm-2
    %select.form-select.form-select-sm.ability{ "aria-label" => "Add ability", name: "#{resource}[permissions][new][ability]", data: { "group-permissions-target": "entryAbility" } }
      %option{ value: "read" } View
      %option{ value: "edit" } Manage
  .col-sm-2
    %button.btn.btn-success.form-control.btn-sm{ type: "button", "aria-label" => "Add group", data: { action: "click->group-permissions#add" } }
      %i.fa-solid.fa-plus{ "aria-hidden" => "true" }
.form-text.text-muted Press + to add a group permission.
