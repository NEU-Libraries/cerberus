%nav{"aria-label" => "breadcrumb"}
  %ol.breadcrumb.align-items-center
    - breadcrumb_trail do |crumb|
      %li.breadcrumb-item{class: crumb.current? ? "active" : "" }
        = link_to_unless crumb.current?, crumb.name, crumb.url, (crumb.current? ? {"aria-current" => "page"} : {})
    -# The "Add a child here" affordance. Suppressed on edit pages via
    -# `show_add: false` (you don't add siblings/children mid-edit).
    -# TODO: replace `user_signed_in?` with a proper Ability check
    -# (e.g. `can?(:create_child, current_resource)`) once piece 5 /
    -# acting-as ships the resource-scoped permission rules. Today we
    -# hide this dropdown from anonymous users to avoid the dead-end
    -# affordance, but a logged-in user without deposit rights still
    -# sees it.
    - if local_assigns.fetch(:show_add, true) && user_signed_in?
      %li.breadcrumb-item
        .dropdown.breadcrumb-add
          %a.text-decoration-none{"aria-expanded" => "false", "data-bs-toggle" => "dropdown", :type => "button"}
            %i.fa-regular.fa-square-plus
            .ms-1.d-inline
              Add
          %ul.dropdown-menu{"aria-labelledby" => "dropdownMenuButton1"}
            - if controller_name == "communities"
              %li
                %a.dropdown-item{:href => new_community_path(:parent_id => "#{params[:id]}")} New Community
              %li
                %a.dropdown-item{:href => new_collection_path(:parent_id => "#{params[:id]}")} New Collection
            - elsif controller_name == "collections"
              %li
                %a.dropdown-item{:href => new_collection_path(:parent_id => "#{params[:id]}")} New Collection
              %li
                %a.dropdown-item{:href => new_work_path(:parent_id => "#{params[:id]}")} New Work
            - else
              %li
                %a.dropdown-item{:href => "#"} Upload File
    - if block_given?
      = yield
