<ul class="navbar-nav">
  <%= render_nav_actions do |config, action|%>
    <li class="nav-item"><%= action %></li>
  <% end %>

  <% if has_user_authentication_provider? %>
    <% if current_user %>
      <% if current_user.messageable? %>
        <li class="nav-item">
          <%= link_to messages_path, class: 'nav-link inbox-nav-link', 'aria-label': inbox_aria_label do %>
            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
            <% if unread_messages_count.positive? %>
              <span class="inbox-nav-link__badge"><%= unread_messages_count %></span>
            <% end %>
          <% end %>
        </li>
      <% end %>
      <% unless current_user.to_s.blank? -%>
        <%# The split button consolidates "things this user can do" (My Sets,
            Admin) behind the caret; the name itself stays a profile link.
            Users with no menu entries (guests) keep the plain name link. %>
        <% if current_user.curates_sets? || current_user.admin? %>
          <li class="nav-item d-flex align-items-center">
            <div class="btn-group user-menu">
              <%= link_to current_user, atlas_user_path, class: 'btn btn-link user-menu-link' %>
              <button type="button" class="btn btn-link user-menu-link dropdown-toggle dropdown-toggle-split"
                      data-bs-toggle="dropdown" aria-expanded="false">
                <span class="visually-hidden">Toggle user menu</span>
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <% if current_user.curates_sets? %>
                  <li>
                    <%= link_to sets_path, class: 'dropdown-item' do %>
                      <i class="fa-solid fa-layer-group me-2" aria-hidden="true"></i>My Sets
                    <% end %>
                  </li>
                <% end %>
                <%# Precise gate: role tier AND at least one group-unlocked
                    Loader, so staff without loader groups get no dead end.
                    The registry is a tiny local AR table — exists? is cheap. %>
                <% if current_user.loader_tier? && Loader.available_to(current_user).exists? %>
                  <li>
                    <%= link_to loaders_path, class: 'dropdown-item' do %>
                      <i class="fa-solid fa-truck-ramp-box me-2" aria-hidden="true"></i>My Loaders
                    <% end %>
                  </li>
                <% end %>
                <% if current_user.admin? %>
                  <li>
                    <%= link_to admin_root_path, class: 'dropdown-item' do %>
                      <i class="fa-solid fa-screwdriver-wrench me-2" aria-hidden="true"></i>Admin
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to current_user, atlas_user_path, class: 'nav-link' %>
          </li>
        <% end %>
        <li class="nav-item">
          <%= link_to t('blacklight.header_links.logout'), destroy_user_session_path, data: { turbo_method: :delete }, class: 'nav-link' %>
        </li>
      <% end %>
      <% else %>
        <li class="nav-item">
          <%# switch to dedicated atlas login page? %>
          <%= link_to "Login", atlas_login_path, class: 'nav-link' %>
          <%# <%= link_to t('blacklight.header_links.login'), new_user_session_path, class: 'nav-link' %>
        </li>
    <% end %>
  <% end %>
</ul>