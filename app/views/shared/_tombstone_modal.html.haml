-# Tombstone confirm modal — used on community/collection/work show pages.
-#
-# Locals:
-#   id   — the resource ID, used to scope modal/label DOM ids
-#   kind — human noun ("community", "collection", "work")
-#   path — POST route that performs the tombstone
- modal_id = "tombstone-modal-#{id}"
- label_id = "tombstone-label-#{id}"

%button.btn.btn-link.px-3.text-danger.p-0.align-baseline{type: 'button',
                                                         data: { 'bs-toggle': 'modal',
                                                                 'bs-target': "##{modal_id}" }}
  Withdraw

.modal.fade{id: modal_id, tabindex: '-1', 'aria-labelledby': label_id, 'aria-hidden': 'true'}
  .modal-dialog.modal-dialog-centered
    .modal-content
      .modal-header
        %h5.modal-title{id: label_id} Confirm withdrawal
        %button.btn-close{type: 'button', 'aria-label': 'Close', data: { 'bs-dismiss': 'modal' }}
      .modal-body
        %p
          Are you sure you want to withdraw this
          = "#{kind}?"
        %p.small.text-muted.mb-0
          The record will be hidden from public discovery and replaced by a withdrawn stub. Restoration is operator-only.
      .modal-footer
        %button.btn.btn-secondary{type: 'button', data: { 'bs-dismiss': 'modal' }} Cancel
        = button_to 'Withdraw', path, method: :post, class: 'btn btn-danger', form: { class: 'd-inline' }
