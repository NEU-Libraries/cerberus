-# Generic fallback renderer for an audit event row.
-#
-# Locals:
-#   event — a single AuditEvent hash from atlas_rb
%tr.audit-event
  %td.text-nowrap.small= Time.iso8601(event['occurred_at']).strftime('%Y-%m-%d %H:%M UTC')
  %td
    %span.badge.bg-secondary= event['action']
  %td.small= event['actor_nuid']
  %td.small.text-muted= event['on_behalf_of_nuid'].presence || '—'
