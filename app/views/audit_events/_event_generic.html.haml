-# Generic fallback renderer for an audit event row. Action types the
-# helper hasn't been taught about (new event verbs from piece 5 etc.)
-# land here — `audit_event_action_badge` falls through to a neutral
-# descriptor with the raw action humanised as the label.
%tr.audit-event.audit-event--generic
  %td= audit_event_timestamp(event)
  %td= audit_event_resource_badge(event)
  %td= audit_event_action_badge(event)
  %td= audit_event_nuid(event['actor_nuid'])
  %td= audit_event_nuid(event['on_behalf_of_nuid'])
