%h3.py-3 Work Metadata

%p.text-muted
  Your file was uploaded successfully. Please review and update the metadata below.

= bootstrap_form_tag(url: metadata_work_path(params[:id]), method: :patch) do |f|
  = bootstrap_fields_for :work do |c|
    = c.text_field :title, value: @work.title, label: 'Title', help: 'A descriptive title for this work.'
    = c.text_area :description, rows: 8, value: @work.description, label: 'Abstract', help: 'A short summary describing the work.'

  %h4.pt-4.pb-2 Permissions
  .row
    .col-sm
      %h5.pb-2 General Permissions
      %select.form-select.form-select-sm#mass{name: "mass", "aria-label" => "General permissions"}
        %option{value: "public", selected: @public ? "selected" : nil} Public
        %option{value: "private", selected: @public ? nil : "selected"} Private
      %ul.small.pt-2
        %li Setting to 'public' will allow anyone accessing the site to see your item.
        %li Setting to 'private' will only allow groups that are explicitly chosen to see your item.
    .col-sm
      %h5.pb-2 Embargo Release Date
      %input.form-select.form-select-sm#embargo{name: "work[permissions][embargo]", type: "date", value: @embargo}/
      %label.small.py-3{for: "embargo"} If this item is embargoed, please enter the release date.

  = render 'shared/group_permissions', resource: 'work'

  .well.p-3.my-3.rounded-3
    = f.button :submit, class: 'btn btn-success'
    -# TODO: Cancel here means "cancel the upload entirely" — not "don't save
    -# metadata". When the Tombstone feature lands, point this at it so the
    -# half-formed Work is properly torn down rather than left orphaned.
    = link_to 'Cancel', work_path(params[:id]), class: 'btn btn-warning'
