%h2.py-2
  Upload File

= form_tag('/works', multipart: true) do |f|
  %input{type: "hidden", value: params[:parent_id], name: "parent_id"}/
  .mb-3
    %label.form-label{:for => "binary"} Default file input example
    %input#binary.form-control{:name => "binary", :type => "file"}/
  - if current_user&.admin? || current_user&.privileged?
    .well.p-3.my-3.rounded-3
      %fieldset
        %legend.h6.mb-2 Depositor attribution
        .form-check
          = radio_button_tag 'upload_as', 'myself', true, class: 'form-check-input', id: 'upload_as_myself'
          %label.form-check-label{for: 'upload_as_myself'}
            Upload as myself
            %span.text-muted.small.ms-1 (I am the depositor)
        .form-check
          = radio_button_tag 'upload_as', 'proxy', false, class: 'form-check-input', id: 'upload_as_proxy'
          %label.form-check-label{for: 'upload_as_proxy'}
            Upload as proxy
            %span.text-muted.small.ms-1 (collection owner is the depositor; I am recorded as proxy_uploader)
  = submit_tag "Upload", class: 'btn btn-primary'
