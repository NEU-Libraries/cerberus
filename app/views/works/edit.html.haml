- content_for(:container_header) do
  = render 'shared/breadcrumbs', show_add: false

%h3.py-3 Edit Work

- show_history = can?(:read, :audit_event)
%ul.nav.nav-tabs{"data-controller" => "tab-hash"}
  %li.nav-item
    %button#metadata-tab.nav-link.active{"aria-controls" => "metadata", "aria-selected" => "true", "data-bs-target" => "#metadata", "data-bs-toggle" => "tab", role: "tab", type: "button"} Metadata
  %li.nav-item
    %button#advanced-tab.nav-link{"aria-controls" => "advanced", "aria-selected" => "false", "data-bs-target" => "#advanced", "data-bs-toggle" => "tab", role: "tab", type: "button"} Advanced
  %li.nav-item
    %button#permissions-tab.nav-link{"aria-controls" => "permissions", "aria-selected" => "false", "data-bs-target" => "#permissions", "data-bs-toggle" => "tab", role: "tab", type: "button"} Permissions
  %li.nav-item
    %button#move-tab.nav-link{"aria-controls" => "move", "aria-selected" => "false", "data-bs-target" => "#move", "data-bs-toggle" => "tab", role: "tab", type: "button"} Move
  %li.nav-item
    %button#delete-tab.nav-link{"aria-controls" => "delete", "aria-selected" => "false", "data-bs-target" => "#delete", "data-bs-toggle" => "tab", role: "tab", type: "button"} Delete
  %li.nav-item
    %a.nav-link{href: xml_editor_path(params[:id])} XML
  - if show_history
    %li.nav-item
      %button#history-tab.nav-link{"aria-controls" => "history", "aria-selected" => "false", "data-bs-target" => "#history", "data-bs-toggle" => "tab", role: "tab", type: "button"} History

.tab-content
  #metadata.tab-pane.active{"aria-labelledby" => "metadata-tab", role: "tabpanel"}
    .py-2.px-1
      = bootstrap_form_tag(url: work_path(params[:id]), method: :patch, multipart: true) do |f|
        = f.hidden_field :id, value: params[:id]
        %label.form-label{:for => "thumbnail"} Thumbnail
        %input#thumbnail.form-control.mb-3{:name => "thumbnail", :type => "file"}/
        = bootstrap_fields_for :work do |c|
          = render 'shared/descriptive_fields', f: c, descriptive: @descriptive, keywords: true
        .well.p-3.my-3.rounded-3
          = f.button :submit, class: "btn btn-success"
          = link_to "Cancel", work_path(params[:id]), class: "btn btn-warning"
  #advanced.tab-pane{"aria-labelledby" => "advanced-tab", role: "tabpanel"}
    .py-2.px-1
      = bootstrap_form_tag(url: work_path(params[:id]), method: :patch, multipart: true) do |f|
        = f.hidden_field :id, value: params[:id]
        = bootstrap_fields_for :work do |c|
          = render 'works/advanced_fields', f: c, advanced: @advanced
        .well.p-3.my-3.rounded-3
          = f.button :submit, class: "btn btn-success"
          = link_to "Cancel", work_path(params[:id]), class: "btn btn-warning"
  #permissions.tab-pane{"aria-labelledby" => "permissions-tab", role: "tabpanel"}
    .py-2.px-1{ data: { controller: "group-permissions", "group-permissions-resource-value": "work" } }
      = bootstrap_form_tag(url: work_path(params[:id]), method: :patch, multipart: true) do |f|
        .row
          .col-sm
            %h5.pb-2
              General Permissions
            %select.form-select.form-select-sm#mass{name: "mass", "aria-label" => "Default select example"}
              %option{value: "public", selected: @public ? "selected" : nil} Public
              %option{value: "private", selected: @public ? nil : "selected"} Private
            %ul.small.pt-2
              %li Setting to 'public' will allow anyone accessing the site to see your item.
              %li Setting to 'private' will only allow groups that are explicitly chosen to see your item.
          .col-sm
            %h5.pb-2 Embargo Release Date
            %input.form-select.form-select-sm#embargo{name: "work[permissions][embargo]", type: "date", value: @embargo}/
            %label.small.py-3{for: "embargo"} If this item is embargoed, please enter the release date.
        = render 'shared/group_permissions', resource: 'work'
        %div
          .well.p-3.my-3.rounded-3
            = f.button :submit, class: "btn btn-success"
            = link_to "Cancel", work_path(params[:id]), class: "btn btn-warning"
  #move.tab-pane{"aria-labelledby" => "move-tab", role: "tabpanel"}
    .py-2.px-1
      %p.text-muted.small.mb-3
        Ask the DRS staff to move this work to a different collection. Your request is sent to the staff inbox — they will follow up with you there.
      = form_with url: request_change_work_path(params[:id]), method: :post do
        = hidden_field_tag :request_action, "move"
        .well.p-3.my-3.rounded-3
          %label.form-label{for: "move_note"} Destination collection
          %textarea.form-control#move_note{name: "request_note", rows: 3, required: true, placeholder: "Name the collection this work should move to."}
          .mt-3
            %button.btn.btn-primary{type: "submit"}
              %i.fa-solid.fa-folder-open.me-1{"aria-hidden" => "true"}
              Request move
            = link_to "Cancel", work_path(params[:id]), class: "btn btn-light"
  #delete.tab-pane{"aria-labelledby" => "delete-tab", role: "tabpanel"}
    .py-2.px-1
      %p.text-muted.small.mb-3
        Ask the DRS staff to delete (withdraw) this work. Your request is sent to the staff inbox — they will follow up with you there.
      = form_with url: request_change_work_path(params[:id]), method: :post do
        = hidden_field_tag :request_action, "withdraw"
        .well.p-3.my-3.rounded-3
          %label.form-label{for: "delete_note"} Reason (optional)
          %textarea.form-control#delete_note{name: "request_note", rows: 3, placeholder: "Optionally, tell the staff why this work should be deleted."}
          .mt-3
            %button.btn.btn-danger{type: "submit"}
              %i.fa-solid.fa-trash-can.me-1{"aria-hidden" => "true"}
              Request deletion
            = link_to "Cancel", work_path(params[:id]), class: "btn btn-light"
  - if show_history
    #history.tab-pane{"aria-labelledby" => "history-tab", role: "tabpanel"}
      = render 'audit_events/history', resource_id: params[:id]
