- content_for(:container_header) do
  = render 'shared/breadcrumbs' do
    - if @files.present?
      %li.ms-auto.d-flex.align-items-center
        = link_to '#downloads', class: 'btn btn-sm btn-outline-dark' do
          = "Downloads (#{@files.size})"
          %span.fa-solid.fa-arrow-down.ms-1{'aria-hidden' => true}

.container
  .clearfix.pt-1
  .row
    .col-md-6.order-md-1.order-2
      = render partial: "thumbnail"
    .col-md-6.order-md-2.order-1
      = @mods.html_safe

.clearfix.mb-4

.container
  .row
    .col-md-12
      = render partial: 'downloads', locals: { files: @files }
