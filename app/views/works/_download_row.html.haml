-# One downloadable-asset row, shared by the work-show Downloads card
-# (_downloads) and the Downloads modal frame (downloads). `work_noid` is the
-# parent work. Both Blob rows and derivative (S/M/L) rows get an "Add to queue"
-# control — keyed on the blob noid, or on the derivative `use` respectively.
-#
-# Delegate rows (S/M/L renditions) carry a gated-host URI, so they route
-# through DerivativeDownloadsController — which authorizes the tier and
-# redirects to a signed URL — rather than linking the URI directly. They are
-# always image renditions, so they take the image icon even though the
-# pointer-only delegate carries no mime type.
- display_label = file.label.presence || file[:use]
- icon = file[:uri].present? ? file_type_icon('image/jpeg') : file_type_icon(file.mime_type)
%li.list-group-item.d-flex.align-items-center
  %span.fa-regular{class: icon, 'aria-hidden' => true}
  -# Label, filename, and size read inline on one baseline. The filename
  -# (with extension) is muted like the size and disambiguates rows that
  -# share a generic label (two "Video File" entries, say). Blob rows carry
  -# a filename; derivative Delegates (uri-backed) don't, so it's conditional.
  .ms-3.flex-grow-1.d-flex.align-items-baseline.flex-wrap.gap-2
    %span.fw-semibold= display_label
    - if file[:filename].present?
      %small.text-muted.text-break= file[:filename]
    - if file[:size]
      %small.text-muted.text-nowrap= number_to_human_size(file[:size])
  - if file[:uri].present?
    = link_to derivative_download_path(work_noid, file[:use]), class: 'btn btn-outline-primary btn-sm ms-3', 'aria-label' => "Download #{display_label}", target: '_blank', rel: 'noopener' do
      %span.fa-solid.fa-download{'aria-hidden' => true}
      %span.ms-1 Download
    = render 'works/queue_button', work_noid: work_noid, use: file[:use], label: display_label
  - else
    = link_to download_path(file.noid), class: 'btn btn-outline-primary btn-sm ms-3', 'aria-label' => "Download #{display_label}", data: { turbo: false } do
      %span.fa-solid.fa-download{'aria-hidden' => true}
      %span.ms-1 Download
    = render 'works/queue_button', work_noid: work_noid, blob_noid: file.noid, label: display_label
