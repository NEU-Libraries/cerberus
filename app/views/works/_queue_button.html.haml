-# "Add to queue" control for one content Blob, in a stable #queue-control-<noid>
-# wrapper so the add action's turbo_stream can swap it to the in-queue state.
-# Add-only here; removal lives on the queue page.
- label = local_assigns[:label].presence || 'this file'
%span.ms-2{id: "queue-control-#{blob_noid}"}
  - if download_queue_includes?(work_noid, blob_noid)
    %span.btn.btn-outline-success.btn-sm.disabled{'aria-label' => "#{label} is in your download queue"}
      %i.fa-solid.fa-check.me-1{'aria-hidden' => true}
      In queue
  - else
    = button_to download_queue_items_path(work_noid: work_noid, blob_noid: blob_noid),
        class: 'btn btn-outline-secondary btn-sm', form: { class: 'd-inline' },
        'aria-label' => "Add #{label} to download queue" do
      %i.fa-solid.fa-cart-arrow-down.me-1{'aria-hidden' => true}
      Add to queue
