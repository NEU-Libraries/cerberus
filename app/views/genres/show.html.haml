- title = @genre.presence || 'Browse by category'
- content_for(:page_title) do
  = title
-# Heading well rides :container_header so it spans the full main width above the
-# sidebar/results row, matching the People landing. The category is named here;
-# the page shows the works curated into that category's showcases (see
-# FeaturedCategory), not a genre-facet browse.
-# Show the genre's own icon (Datasets → fa-database, etc.), matching the homepage
-# Featured Content gateways; fall back to the bookmark for the bare browse landing
-# or an unknown category.
- heading_icon = FeaturedContent.icon_for(@genre) || 'fa-bookmark'
- content_for(:container_header) do
  .container.p-4.my-3.well.rounded-3
    %h3.mb-1
      %i.fa-solid.text-primary.me-2{ class: heading_icon, 'aria-hidden' => 'true' }
      = title
    .text-muted.mb-0
      - if @genre.present?
        Featured content in #{@genre}.
      - else
        Browse the repository by scholarly category.

- if @response.documents.present?
  - content_for(:sidebar) do
    = render 'catalog/search_sidebar'

= render 'catalog/search_results'
= render 'shared/downloads_modal'
