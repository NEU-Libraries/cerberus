/ Multipage loader preview-then-confirm. A manifest concatenates many items
/ (each becomes its own Work); this renders MultipagePreview::Result as a
/ sanity check — how many items the sheet holds plus the FIRST item in detail
/ — so the librarian can confirm they uploaded the right spreadsheet before
/ anything is minted. Per-item validation is the run-time job's work, not the
/ preview's. Reuses the .admin-registry / .load-report-overview /
/ .ingest-status chrome — no bespoke CSS.
.admin-registry.my-3
  %header.admin-registry__head
    %span.admin-registry__title
      %i.fa-solid.fa-eye{'aria-hidden' => 'true'}
      Preview
      %span.text-muted.fw-normal= load_report.source_filename
    %span.admin-registry__subtitle
      %i.fa-solid.fa-folder-tree{'aria-hidden' => 'true'}
      = link_to loader.display_name, loader_loads_path(loader), class: 'text-decoration-none'

  .admin-registry__body
    - if preview.structural_errors.any?
      .alert.alert-danger.d-flex.gap-2.mb-0
        %i.fa-solid.fa-circle-exclamation.mt-1{'aria-hidden' => 'true'}
        %div
          %p.fw-semibold.mb-1 This archive can't be processed as a multipage load.
          %ul.mb-0.small
            - preview.structural_errors.each do |err|
              %li= err
    - else
      %p.text-muted.small.mb-3
        This archive contains
        %strong= pluralize(preview.item_count, 'item')
        (#{pluralize(preview.page_count, 'page')}). Each item becomes its own Work; any item with problems is skipped and noted in the report. Nothing is created until you confirm.

      .load-report-overview
        .load-report-overview__meta
          %span.load-report-overview__label Mode
          %span.load-report-overview__value
            %span.ingest-status{style: '--ingest-tone: #18bc9c'}
              %i.fa-solid.fa-layer-group{'aria-hidden' => 'true'}
              Create multipage Works
          %span.load-report-overview__label Items
          %span.load-report-overview__value= preview.item_count
          %span.load-report-overview__label Pages
          %span.load-report-overview__value= preview.page_count
          - if load_report.parent_collection_id.present?
            %span.load-report-overview__label Destination
            %span.load-report-overview__value
              %code.admin-registry-table__id= load_report.parent_collection_id

    - if preview.ok? && preview.first_item
      - first = preview.first_item
      %p.text-muted.small.mt-4.mb-2
        %i.fa-solid.fa-eye.me-1{'aria-hidden' => 'true'}
        Sample — first item
        - if first.label.present?
          %span.fw-semibold.text-body= first.label

      - if first.pages.any?
        .table-responsive
          %table.table.table-borderless.admin-registry-table.ingest-table
            %caption.visually-hidden Pages of the first item, in the order they will attach to its Work
            %thead
              %tr
                %th{scope: 'col'} Seq
                %th{scope: 'col'} Page file
                %th{scope: 'col'} Title
                %th{scope: 'col'} Last item
            %tbody
              - first.pages.each do |page|
                %tr
                  %td= page.sequence
                  %td
                    %code.admin-registry-table__id= page.file_name
                  %td.small= page.title
                  %td
                    - if page.last_item?
                      %i.fa-solid.fa-flag-checkered.text-muted{'aria-hidden' => 'true'}
                      %span.visually-hidden Last item

      - if preview.mods_xml.present?
        / The first item's MODS, two-up: raw document beside Atlas's rendered
        / HTML view — same raw-vs-rendered pairing as the XML editor and _preview.
        .row.g-3.mt-2
          .col-lg-6
            %span.load-report-overview__label Raw MODS
            %pre.border.border-1.rounded-3.bg-light.p-3.small.mt-1.mb-0{style: 'max-height: 26rem; overflow: auto;'}= preview.mods_xml
          .col-lg-6
            %span.load-report-overview__label Rendered
            - if preview.decorated_html.present?
              .border.border-1.rounded-3.bg-white.p-3.mt-1.mb-0{style: 'max-height: 26rem; overflow: auto;'}
                = preview.decorated_html.html_safe
            - else
              .border.border-1.rounded-3.bg-light.p-3.mt-1.mb-0.text-muted.small
                %i.fa-solid.fa-eye-slash.me-1{'aria-hidden' => 'true'}
                The rendered view appears once the MODS validates.

    .d-flex.gap-2.align-items-center.mt-4
      - if preview.ok?
        = button_to confirm_loader_load_path(loader, load_report), method: :patch, class: 'btn btn-primary' do
          %i.fa-solid.fa-play.me-1{'aria-hidden' => 'true'}
          Confirm &amp; run
      = button_to loader_load_path(loader, load_report), method: :delete, class: 'btn btn-outline-danger', data: { turbo_confirm: 'Discard this upload? The staged archive will be removed.' } do
        %i.fa-solid.fa-trash-can.me-1{'aria-hidden' => 'true'}
        Discard
