.admin-registry.my-3
  %header.admin-registry__head
    %span.admin-registry__title
      %i.fa-solid.fa-cloud-arrow-up{'aria-hidden' => 'true'}
      New upload
      %span.text-muted.fw-normal to #{@loader.display_name}
    %span.admin-registry__subtitle
      %i.fa-solid.fa-folder-tree{'aria-hidden' => 'true'}
      = @loader.slug
  .admin-registry__body
    = form_with model: [@loader, @load_report], url: loader_loads_path(@loader), local: true, html: { class: 'admin-registry-form', multipart: true } do |f|
      - if @load_report.errors.any?
        .alert.alert-danger
          %p.fw-semibold.mb-1
            %i.fa-solid.fa-circle-exclamation.me-1{'aria-hidden' => 'true'}
            Couldn't begin this batch.
          %ul.mb-0.small
            - @load_report.errors.full_messages.each do |msg|
              %li= msg
      - if flash.now[:alert]
        .alert.alert-warning
          %i.fa-solid.fa-triangle-exclamation.me-1{'aria-hidden' => 'true'}
          = flash.now[:alert]

      .admin-registry-form__section
        .mb-0
          = f.label :archive, class: 'admin-registry-form__label' do
            %i.fa-solid.fa-file-zipper{'aria-hidden' => 'true'}
            Archive file
          = f.file_field :archive, class: 'form-control', accept: '.tar,.zip', required: true
          - if @loader.multipage?
            .admin-registry-form__hint
              Accepted formats:
              %code.admin-registry-table__id .tar
              or
              %code.admin-registry-table__id .zip
              \. Must contain a
              %code.admin-registry-table__id manifest.xlsx
              naming one MODS XML (Sequence 0) and the page images in order (Sequence 1 and up, Last Item on the final page). The whole archive becomes a single Work with ordered pages; you'll review the full page list before anything runs.
          - elsif @loader.xml?
            .admin-registry-form__hint
              Accepted formats:
              %code.admin-registry-table__id .tar
              or
              %code.admin-registry-table__id .zip
              \. Must contain a
              %code.admin-registry-table__id manifest.xlsx
              plus the MODS XML files it references. Each row updates an existing object by PID/NOID, or creates a new one from a named content file. You'll preview the first row before the batch runs.
          - else
            .admin-registry-form__hint
              Accepted formats:
              %code.admin-registry-table__id .tar
              or
              %code.admin-registry-table__id .zip
              \. Each JPEG inside must carry valid IPTC tags — Headline and Keywords are required; By-line, Description, Category, City + State are optional but recorded.

      .admin-registry-form__section
        .mb-0
          = f.label :parent_collection_id, class: 'admin-registry-form__label' do
            %i.fa-solid.fa-folder-open{'aria-hidden' => 'true'}
            Destination collection
          - if @loader.iptc?
            -# IPTC safety rail: boxed to the configured root collection's children.
            - if @destinations.any?
              = f.select :parent_collection_id,
                         options_for_select(@destinations.map { |c| [c.title, c.id] }, @load_report.parent_collection_id),
                         { include_blank: 'Select a collection…' },
                         class: 'form-select admin-registry-form__input--id', required: true
            - else
              .alert.alert-warning.mb-0
                %i.fa-solid.fa-triangle-exclamation.me-1{'aria-hidden' => 'true'}
                No destination collections found under
                %code.admin-registry-table__id= @loader.root_collection
                \. Ask an admin to verify the loader's root collection is configured correctly.
          - else
            -# XML / multipage: librarian-trusted — pick any collection by title
            -# (NOID shown for visual confirmation) or paste a NOID directly.
            .position-relative{ data: { controller: 'collection-picker',
              collection_picker_url_value: loader_loads_collection_search_path(@loader) } }
              %input.form-control.admin-registry-form__input--id#load_report_collection_query{ type: 'text',
                autocomplete: 'off', placeholder: 'Search by collection title, or paste a NOID…',
                value: @load_report.parent_collection_id,
                data: { collection_picker_target: 'query', action: 'input->collection-picker#search' } }
              = f.hidden_field :parent_collection_id, data: { collection_picker_target: 'hidden' }
              .list-group.inbox-typeahead{ hidden: true, data: { collection_picker_target: 'results' } }
            - if @loader.multipage?
              .admin-registry-form__hint
                Where the new multipage Work lands — any collection.
            - else
              .admin-registry-form__hint
                Where newly-created Works land — any collection. Rows that update an existing object by PID/NOID ignore this.

      .d-flex.gap-2.align-items-center.mt-4
        = f.submit 'Upload', class: 'btn btn-primary', disabled: (@loader.iptc? && @destinations.empty?)
        = link_to loader_loads_path(@loader), class: 'btn btn-warning' do
          Cancel
