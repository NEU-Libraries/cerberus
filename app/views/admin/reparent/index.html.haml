.admin-registry.my-3
  %header.admin-registry__head
    %span.admin-registry__title
      %i.fa-solid.fa-sitemap{'aria-hidden' => 'true'}
      Re-parent / Move
    .admin-registry__head-actions
      %span.admin-registry__subtitle
        %i.fa-solid.fa-lock{'aria-hidden' => 'true'}
        Admin-only

  .admin-registry__empty
    %i.fa-solid.fa-screwdriver-wrench.admin-registry__empty-icon{'aria-hidden' => 'true'}
    %p.mb-1.fw-semibold.text-body Move workflow coming next
    %p.mb-0.small.text-muted
      Pick a Collection or Community, choose a new parent, and confirm the move. The Atlas re-parent endpoint and atlas_rb binding are already in place — this surface wires the UI to them.

  %p.mt-3.mb-0
    = link_to admin_root_path, class: 'admin-registry-table__edit' do
      %i.fa-solid.fa-arrow-left{'aria-hidden' => 'true'}
      Back to actions
