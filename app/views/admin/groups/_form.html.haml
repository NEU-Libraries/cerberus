= form_with model: [:admin, @group], local: true, html: { class: 'admin-registry-form' } do |f|
  - if @group.errors.any?
    .alert.alert-danger
      %p.fw-semibold.mb-1
        %i.fa-solid.fa-circle-exclamation.me-1{'aria-hidden' => 'true'}
        Couldn't save this group name.
      %ul.mb-0.small
        - @group.errors.full_messages.each do |msg|
          %li= msg

  .admin-registry-form__section
    %h3.admin-registry-form__section-title
      %i.fa-solid.fa-tags{'aria-hidden' => 'true'}
      Group name
    .mb-3
      = f.label :raw, 'Grouper group', class: 'admin-registry-form__label' do
        %i.fa-solid.fa-users{'aria-hidden' => 'true'}
        Grouper group
      = f.text_field :raw, class: 'form-control admin-registry-form__input--id', placeholder: 'northeastern:drs:repository:loaders:marcom', autocomplete: 'off'
      .admin-registry-form__hint
        The raw colon-separated Grouper identifier, exactly as it appears on user and object records.
    .mb-0
      = f.label :cosmetic, 'Display name', class: 'admin-registry-form__label' do
        %i.fa-solid.fa-id-card{'aria-hidden' => 'true'}
        Display name
      = f.text_field :cosmetic, class: 'form-control', placeholder: 'Marketing and Communications'
      .admin-registry-form__hint
        The friendly label shown wherever this group surfaces (inbox recipients, sharing, permissions). Without it the raw string is shown as-is.

  .d-flex.gap-2.align-items-center.mt-4
    = f.submit class: 'btn btn-primary'
    = link_to admin_groups_path, class: 'btn btn-outline-secondary' do
      %i.fa-solid.fa-arrow-left.me-1{'aria-hidden' => 'true'}
      Cancel
