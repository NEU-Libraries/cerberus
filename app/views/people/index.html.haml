- content_for(:page_title) do
  = @community ? 'Faculty & Staff' : 'People'
-# Breadcrumb + heading well ride :container_header so they span the full main
-# width above the sidebar/results row, matching the community/collection/work
-# show pages (anything outside :container_header lands in the results column).
- content_for(:container_header) do
  -# Community-scoped browse only: the trail (built in the controller) leads
  -# through the community and its ancestors. The global /people index has no
  -# parent, so it shows no breadcrumb. show_add suppresses the "add a child"
  -# affordance (a Faculty & Staff browse isn't a container parent).
  - if @community
    = render 'shared/breadcrumbs', show_add: false

  .container.p-4.my-3.well.rounded-3
    .d-flex.align-items-start
      .flex-grow-1
        %h3.mb-1
          %i.fa-solid.fa-users.text-primary.me-2{ 'aria-hidden' => 'true' }
          = @community ? 'Faculty & Staff' : 'People'
        .text-muted.mb-0
          - if @community
            Browse the people affiliated with #{@community.title}.
          - else
            Browse people in the repository.
      - if @response.documents.present? || params[:q].present?
        .ms-md-3
          = render 'shared/scoped_search',
            path: (@community ? community_people_path(params[:community_id]) : people_path),
            label: (@community ? 'Search faculty & staff' : 'Search people')

- if @response.documents.present?
  - content_for(:sidebar) do
    = render 'catalog/search_sidebar'

= render 'catalog/search_results'
