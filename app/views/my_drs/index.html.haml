- content_for(:page_title) { 'My DRS' }

-# Heading well rides :container_header so it spans the full main width above the
-# two-space row, matching the community / collection / People show pages.
- content_for(:container_header) do
  .container.p-4.my-3.well.rounded-3
    .d-flex.align-items-start
      .flex-grow-1
        %h3.mb-1
          %i.fa-solid.fa-folder-tree.text-primary.me-2{ 'aria-hidden' => 'true' }
          My DRS
        %p.text-muted.mb-0
          Your personal workspace and what you've published to your community.
      .ms-md-3
        = link_to new_work_path, class: 'btn btn-primary' do
          %i.fa-solid.fa-plus.me-1{ 'aria-hidden' => 'true' }
          Deposit

-# Multi-account switcher — only for a person whose NUID holds more than one
-# account. Full-width above the workspace/published split.
- if @accounts.to_a.size > 1
  = render 'accounts', accounts: @accounts

.row.g-4
  -# Published — works promoted into community genre showcases, grouped by category.
  -# Placed first (left) as the outward-facing, professional tier; the teal
  -# section icon is the quiet accent distinguishing it from the personal
  -# workspace tier.
  .col-lg-6
    .my-drs-card.bg-white.border.rounded-3.h-100.overflow-hidden.shadow-sm
      .my-drs-card__head.p-3
        %h5.mb-1
          %i.fa-solid.fa-graduation-cap.text-success.me-2{ 'aria-hidden' => 'true' }
          Published to my community
        %p.small.mb-0.text-muted
          Promoted into your community's featured showcases, grouped by category.
      - if @published.present?
        -# Registry ledger (admin-registry-table). The showcase category is promoted
        -# from a section header to a real grouped column (rowspan), so the grouping
        -# is table structure rather than decoration — Category | Work.
        .table-responsive
          %table.table.table-borderless.admin-registry-table
            %thead
              %tr
                %th{ scope: 'col' } Category
                %th{ scope: 'col' } Work
            %tbody
              - @published.each do |label, works|
                - works.each_with_index do |work, i|
                  %tr
                    - if i.zero?
                      %td.align-top{ rowspan: works.size }
                        %span.text-uppercase.small.text-muted.fw-semibold= label
                    %td.admin-registry-table__name
                      %i.fa-regular.fa-file.text-muted.me-2{ 'aria-hidden' => 'true' }
                      = link_to Array(work['title_tsim']).first.presence || '(untitled)', work_path(work)
      - else
        .p-3
          %p.text-muted.mb-0
            Nothing published yet. Choose “Publish to my community” when you deposit a file.

  -# Workspace — the depositor's own collections (v1's "User Created Collections").
  -# Card-shell matches the audit-history register: white body, near-white header
  -# strip, gray border, subtle shadow. No rail — the neutral archive icon is
  -# enough to mark the personal (non-promoted) tier.
  .col-lg-6
    .my-drs-card.bg-white.border.rounded-3.h-100.overflow-hidden.shadow-sm.d-flex.flex-column
      .my-drs-card__head.p-3
        %h5.mb-1
          %i.fa-solid.fa-box-archive.text-secondary.me-2{ 'aria-hidden' => 'true' }
          My workspace
        %p.small.text-muted.mb-0
          Personal collections — discoverable by their own visibility, never promoted.
      - if @workspace_collections.present?
        -# Full-bleed registry ledger (admin-registry-table) — uppercase column
        -# microcopy, warm hover, monospace-grade tabular chrome. Visibility is
        -# the meaningful second column: workspace collections are "discoverable
        -# by their own visibility", so it carries real information here.
        .table-responsive
          %table.table.table-borderless.admin-registry-table
            %thead
              %tr
                %th{ scope: 'col' } Collection
                %th{ scope: 'col' } Visibility
            %tbody
              - @workspace_collections.each do |coll|
                %tr
                  %td.admin-registry-table__name
                    %i.fa-regular.fa-folder-open.text-muted.me-2{ 'aria-hidden' => 'true' }
                    = link_to Array(coll['title_tsim']).first.presence || '(untitled)', collection_path(coll)
                  %td.text-muted.small.text-nowrap
                    - if Array(coll['read_access_group_ssim']).include?('public')
                      %i.fa-solid.fa-globe.me-1{ 'aria-hidden' => 'true' }
                      Public
                    - else
                      %i.fa-solid.fa-lock.me-1{ 'aria-hidden' => 'true' }
                      Private
      - else
        .p-3
          %p.text-muted.mb-0
            No collections yet. Deposit a file to start your workspace.
      -# Action footer, pinned to the card bottom (mt-auto), button right-aligned so
      -# the "add" affordance sits below the rows rather than lost in the header strip.
      - if @personal_root_id.present?
        .p-3.border-top.mt-auto.d-flex.justify-content-end
          = link_to new_collection_path(parent_id: @personal_root_id), class: 'btn btn-sm btn-outline-secondary' do
            %i.fa-solid.fa-plus.me-1{ 'aria-hidden' => 'true' }
            New collection

-# Programmatic access — a personal-access token for the Atlas API, shown only to
-# members of the API group. Full-width below the workspace/published split; the
-# initial (no-token) state, which AtlasTokensController later swaps in place.
- if current_user&.member_of?(Permissions::API_GROUP)
  .mt-4
    = render 'programmatic_access', token: nil, notice: nil
