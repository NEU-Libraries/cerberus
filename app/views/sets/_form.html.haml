-# Shared title/description form (new + edit). The recipe itself is never
-# edited here — works and collections join a set from their own pages, and
-# leave it from the set page's definition panel.
= form_with scope: :set, url: url, method: method do |f|
  .mb-3
    = f.label :title, 'Title', class: 'form-label'
    = f.text_field :title, value: @set['title'], class: 'form-control', required: true, maxlength: 250
  .mb-3
    = f.label :description, 'Description', class: 'form-label'
    = f.text_area :description, value: @set['description'], class: 'form-control', rows: 3
    .form-text Optional — a note to your future self about what this set gathers.
  = f.submit submit_label, class: 'btn btn-primary btn-sm'
  = link_to 'Cancel', cancel_path, class: 'btn btn-outline-secondary btn-sm ms-2'
