%h1.page-header
  Upload File to
  %i
    = @core_file.title

%script{src: "/tus-js/tus.min.js", type: "text/javascript"}

.row
  %fieldset.span4
    %legend
      1. Terms of Service Agreement
    %span.help-block
      Please read and accept the
      %a{href: "/terms"}
        terms of use
    %label.checkbox.required-label{ for: "terms_of_service" }
      I have read and accept the terms of service.
      = check_box_tag 'terms_of_service', 1, nil, data: { activate:  "activate-submit" }
  %fieldset.span4
    %legend
      2. File Upload
    = label_tag "file", "File to upload", class: "required-label"
    = file_field_tag 'file', required: true, "aria-required" => true
  %fieldset.span4
    %legend
      3. MD5 Hash Value
    %span.help-block
      Enter MD5 for hash validation
    = text_field_tag :checksum
- if current_user.proxy_staff?
  .row
    %fieldset.span4
      %legend
        4. Proxy
      = label_tag 'upload_type', 'Upload as myself (I will be the depositor)'
      = radio_button_tag 'upload_type', 'personal', false
      = label_tag 'upload_type', 'Upload as proxy (collection owner will be depositor)'
      = radio_button_tag 'upload_type', 'proxy', false

.progress.progress-striped
  .bar{style: "width:0%"}
.form-actions
  = button_tag "Upload", disabled: "true", class: 'btn btn-large btn-primary activate-submit', data: { disable_with: "Please wait..."}, id: "large-upload-btn"

:javascript
  const input = document.querySelector('input[type=file]')
  const upload_button = document.querySelector('#large-upload-btn')

  upload_button.addEventListener("click", function() {
    $(".progress").show();
    $('#large-upload-btn').prop('disabled', true);
    $('#large-upload-btn').text("Please wait...");

    // Get the selected file from the input element
    var file = input.files[0]
  
    // Create a new tus upload
    var upload = new tus.Upload(file, {
      endpoint: 'https://repository.library.northeastern.edu/tus/',
      retryDelays: [0, 3000, 5000, 10000, 20000],
      chunkSize: 10 * 1024 * 1024,
      metadata: {
        filename: file.name,
        filetype: file.type,
      },
      onError: function (error) {
        console.log('Failed because: ' + error)
      },
      onProgress: function (bytesUploaded, bytesTotal) {
        var percentage = ((bytesUploaded / bytesTotal) * 100).toFixed(2)
        console.log(bytesUploaded, bytesTotal, percentage + '%')
        $('.progress .bar').css(
            'width',
            percentage + '%'
        );
      },
      onSuccess: function () {
        console.log('Download %s from %s', upload.file.name, upload.url);
        $(".progress").after("<div class='alert alert-success'>Your file has been uploaded and is now being processed.</div>");
        spinner = enable_spinner('main-content');
        $.post( "#{create_attached_file_path}", { id: "#{params[:id]}", terms_of_service: "1", upload_type: $('input[name="upload_type"]').val(), checksum: $('#checksum').val(), url: upload.url, original_filename: upload.file.name }, function(data) {window.location = data.url;}, "json" );
      },
    })
  
    // Check if there are any previous uploads to continue.
    upload.findPreviousUploads().then(function (previousUploads) {
      // Found previous uploads so we select the first one.
      if (previousUploads.length) {
        upload.resumeFromPreviousUpload(previousUploads[0])
      }
  
      // Start the upload
      upload.start()
    })
  })
