<%# Cerberus override of Blacklight's catalog/_zero_results.

    Container show pages (communities/collections) render the catalog search
    machinery to list their children, so an EMPTY container falls through to
    this partial — but the user never ran a search, they just clicked into an
    empty thing. Blacklight's "No results found for your search / Try modifying
    your search / Use fewer keywords" advice is nonsensical there.

    We discriminate on params[:q]: a present query is a real search (keep the
    upstream advice); a blank query is a browse/show of an empty container, so
    we render a calm, neutral empty state instead. The "Limit your search"
    sidebar and the sort/per-page controls are suppressed upstream for this
    case (communities/collections show + _search_sidebar guard). %>
<% if params[:q].present? %>
  <h2><%= t 'blacklight.search.zero_results.title' %></h2>
  <div id="documents" class="noresults">
    <h3><%= t 'blacklight.search.zero_results.modify_search' %></h3>
    <ul>
      <li><%= t 'blacklight.search.zero_results.use_fewer_keywords' %></li>
      <% if params[:q] && params[:search_field] && params[:search_field] != blacklight_config.default_search_field&.key %>
        <li>
          <%= t 'blacklight.search.zero_results.search_fields', search_fields: search_field_label(params) %> -
          <%= link_to t('blacklight.search.zero_results.search_everything', field: blacklight_config.default_search_field.label),
                      url_for(search_state.params_for_search(search_field: blacklight_config.default_search_field.key)) %>
        </li>
      <% end %>
    </ul>
  </div>
<% else %>
  <% kind, icon = case controller_name
                  when 'collections' then ['collection', 'fa-folder-open']
                  when 'communities' then ['community',  'fa-users']
                  when 'genres'      then ['category',   'fa-bookmark']
                  else [nil, 'fa-box-open']
                  end %>
  <div id="documents" class="empty-container-state">
    <i class="empty-container-state__icon fa-solid <%= icon %>" aria-hidden="true"></i>
    <h2 class="empty-container-state__title">
      <%= kind ? "This #{kind} is empty" : 'Nothing here yet' %>
    </h2>
    <p class="empty-container-state__hint">Nothing has been added yet.</p>
  </div>
<% end %>
