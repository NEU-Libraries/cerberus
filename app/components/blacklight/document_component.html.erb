<%= content_tag @component,
  id: @id,
  data: {
    'document-id': @document.id.to_s.parameterize,
    'document-counter': @counter,
  },
  itemscope: true,
  itemtype: @document.itemtype,
  class: classes.flatten.join(' ') do %>
  <%= header %>
  <% if body.present? %>
    <%= body %>
  <% else %>
    <div class="document-main-section order-2">
      <%= title %>
      <%= embed %>
      <%= content %>
      <%= metadata %>
      <% metadata_sections.each do |section| %>
        <%= section %>
      <% end %>

      <%# "Full Text Match" — a Solr highlight fragment from the document body
          (all_text_timv), shown only when the query matched inside the text.
          List view only: the gallery component is image-forward and omits it. %>
      <% if @document.has_highlight_field?('all_text_timv') %>
        <div class="full-text-match">
          <div class="full-text-match__label">Full Text Match</div>
          <div class="full-text-match__snippet">… <%= sanitize(@document.highlight_field('all_text_timv').first, tags: %w[em]) %> …</div>
        </div>
      <% end %>

      <% partials.each do |partial| %>
        <%= partial %>
      <% end %>

      <div class="text-end">
        <% if @document.klass == Work %>
          <button type="button"
                  class="btn btn-sm btn-link text-decoration-none p-0 me-2"
                  data-bs-toggle="modal"
                  data-bs-target="#downloadsModal"
                  data-downloads-url="<%= downloads_work_path(@document) %>">
            Downloads
            <i class="fa-solid fa-download ms-1" aria-hidden="true"></i>
          </button>
        <% end %>
        <%# klass_type (string), not klass: in this template's scope a bare
            `Collection` is ViewComponent::Collection, not the app model. %>
        <% if helpers.current_user&.curates_sets? && %w[Work Collection].include?(@document.klass_type) %>
          <a href="#add-to-set-<%= @document.to_param %>"
             class="btn btn-sm btn-link p-0 me-2"
             role="button"
             data-bs-toggle="modal"
             data-controller="tooltip"
             data-bs-title="Add to Set">
            <span class="visually-hidden">Add to set</span>
            <i class="fa-regular fa-clone" aria-hidden="true"></i>
          </a>
        <% end %>
        <%= link_to helpers.report_a_problem_url(@document),
                    class: 'btn btn-sm btn-link p-0 pe-2',
                    target: '_blank',
                    rel: 'noopener',
                    data: { controller: 'tooltip', 'bs-title': 'Report a problem' } do %>
          <span class="visually-hidden">Report a problem</span>
          <i class="fa-regular fa-comment-dots" aria-hidden="true"></i>
        <% end %>
        <%= helpers.document_status_icons(@document) %>
      </div>
      <% if helpers.current_user&.curates_sets? && %w[Work Collection].include?(@document.klass_type) %>
        <%= render 'sets/picker_modal',
                   kind: @document.klass_type.downcase,
                   noid: @document.to_param %>
      <% end %>
    </div>

    <%= thumbnail %>
  <% end %>
  <%= footer %>
<% end %>
