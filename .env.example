ATLAS=0.6.105
#ATLAS_RAILS_MASTER_KEY=123123
# Cantaloupe as reachable from INSIDE the web container, for server-side
# IIIF info.json reads (manifest dimensions). Browsers use the public
# iiif_host; leave unset when the two are the same. In compose:
#CERBERUS_IIIF_INTERNAL_HOST=http://iiif:8182

# Gated-derivative model. MasterJp2 writes both the capped display JP2 and the
# full-res JP2 to the one derivatives dir Cantaloupe reads, distinguished by an
# `open-`/`gated-` filename prefix; the Cantaloupe delegate serves `open-*`
# freely and requires a signed URL / grant cookie for `gated-*`. The signing
# secret is the HMAC key shared with that delegate — set it (identically on the
# iiif service) to enforce gating; unset means dev serves everything ungated.
#CERBERUS_IIIF_SIGNING_SECRET=change-me-shared-with-cantaloupe-delegate
