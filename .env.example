ATLAS=0.6.67
ARCH=amd64
#ATLAS_MASTER_KEY=123123
#ATLAS_TOKEN=321321
# Cantaloupe as reachable from INSIDE the web container, for server-side
# IIIF info.json reads (manifest dimensions). Browsers use the public
# iiif_host; leave unset when the two are the same. In compose:
#CERBERUS_IIIF_INTERNAL_HOST=http://iiif:8182
# Cutover toggle for the signed-assertion relay (cerberus_token replacement).
# Unset/false = legacy ATLAS_TOKEN + User: NUID relay. true = atlas_rb signs a
# short-lived ES256 assertion per request (needs credentials.cerberus_signing_key
# / cerberus_signing_kid). Atlas dual-runs, so flip per-env and roll back freely.
CERBERUS_SIGN_ASSERTIONS=true
