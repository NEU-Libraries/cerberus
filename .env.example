ATLAS=0.6.70
ARCH=amd64
# Atlas's Rails master key — decrypts Atlas's encrypted credentials. Compose
# injects it into the atlas / atlas-test containers as their RAILS_MASTER_KEY.
# Distinct from Cerberus's OWN RAILS_MASTER_KEY (set in CI via docker-compose.ci.yml
# so the web container can decrypt Cerberus credentials and sign Atlas relay
# assertions). Two different master keys — the ATLAS_ prefix is what tells them apart.
#ATLAS_RAILS_MASTER_KEY=123123
# Cantaloupe as reachable from INSIDE the web container, for server-side
# IIIF info.json reads (manifest dimensions). Browsers use the public
# iiif_host; leave unset when the two are the same. In compose:
#CERBERUS_IIIF_INTERNAL_HOST=http://iiif:8182
