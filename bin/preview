#!/usr/bin/env bash
# bin/preview — temporarily apply another branch's diff onto the current
# checkout so the running dev container picks it up via the bind mount.
#
# Usage:
#   bin/preview <branch>     Apply HEAD..<branch> diff and restart web
#   bin/preview --revert     Reverse-apply the active preview
#   bin/preview --status     Show what (if anything) is currently previewed

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PATCH_DIR="$REPO_ROOT/tmp/preview"
STATE_FILE="$PATCH_DIR/.current"
WEB_CONTAINER="cerberus-web-1"

restart_web() {
  if docker ps --format '{{.Names}}' | grep -qx "$WEB_CONTAINER"; then
    docker exec "$WEB_CONTAINER" bundle exec bin/rails restart
  else
    echo "Note: $WEB_CONTAINER is not running; skipping restart."
  fi
}

cmd_status() {
  if [[ -f "$STATE_FILE" ]]; then
    echo "Previewing: $(cat "$STATE_FILE")"
    echo "Revert with: bin/preview --revert"
  else
    echo "No preview active."
  fi
}

cmd_revert() {
  [[ -f "$STATE_FILE" ]] || { echo "No active preview to revert." >&2; exit 1; }
  local branch patch
  branch=$(cat "$STATE_FILE")
  patch="$PATCH_DIR/${branch//\//_}.patch"
  [[ -f "$patch" ]] || { echo "Patch missing at $patch — revert manually." >&2; exit 1; }
  echo "Reverting preview of '$branch'…"
  git -C "$REPO_ROOT" apply -R "$patch"
  rm -f "$patch" "$STATE_FILE"
  restart_web
  echo "Reverted. Working tree is back to HEAD."
}

cmd_apply() {
  local branch="$1"
  [[ -f "$STATE_FILE" ]] && { echo "Preview already active ($(cat "$STATE_FILE")). Revert first." >&2; exit 1; }
  if ! git -C "$REPO_ROOT" diff --quiet || ! git -C "$REPO_ROOT" diff --cached --quiet; then
    echo "Working tree is not clean. Commit or stash first." >&2; exit 1
  fi
  git -C "$REPO_ROOT" rev-parse --verify "$branch" >/dev/null 2>&1 \
    || { echo "Branch '$branch' not found." >&2; exit 1; }

  mkdir -p "$PATCH_DIR"
  local patch="$PATCH_DIR/${branch//\//_}.patch"
  git -C "$REPO_ROOT" diff "HEAD..$branch" > "$patch"
  if [[ ! -s "$patch" ]]; then
    echo "No diff between HEAD and '$branch'. Nothing to preview."
    rm -f "$patch"; exit 0
  fi

  if ! git -C "$REPO_ROOT" apply "$patch"; then
    echo "Patch failed to apply (likely drift between HEAD and '$branch')." >&2
    echo "Rebase the branch onto HEAD, or apply manually." >&2
    rm -f "$patch"; exit 1
  fi
  echo "$branch" > "$STATE_FILE"
  restart_web
  echo "Preview of '$branch' applied. Revert with: bin/preview --revert"
}

case "${1:-}" in
  --revert) cmd_revert ;;
  --status) cmd_status ;;
  -h|--help|"") sed -n '2,8p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) cmd_apply "$1" ;;
esac
