<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Verifying your browser&hellip;</title>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f5f5f5;
      color: #333;
      line-height: 1.6;
    }
    .container {
      max-width: 528px;
      margin: 1rem;
      padding: 2.5rem 2rem;
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      text-align: center;
    }
    h1 {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: #222;
    }
    p { margin-bottom: 1rem; color: #555; }
    p:last-of-type { margin-bottom: 0; }
    a {
      color: #c8102e;
      text-decoration: none;
      font-weight: 500;
    }
    a:hover { text-decoration: underline; }
    .spinner {
      width: 28px; height: 28px;
      margin: 0 auto 1.25rem;
      border: 3px solid #e0e0e0;
      border-top-color: #c8102e;
      border-radius: 50%;
      animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="container">
    <div class="spinner"></div>
    <h1>Verifying your browser&hellip;</h1>
    <p>This only takes a moment. You'll be redirected automatically.</p>
    <form id="challenge-form" method="post" action="/challenge/verify">
      <input type="hidden" name="redirect_url" value="<%= j @redirect_url %>">
      <div class="cf-turnstile"
           data-sitekey="<%= j(@site_key.to_s) %>"
           data-size="invisible"
           data-callback="onTurnstileSuccess"
           data-error-callback="onTurnstileError"></div>
    </form>
    <noscript>
      <div style="text-align: left;">
        <p>JavaScript is required to complete verification. Please
          <a href="http://repository.library.northeastern.edu/users/auth/shibboleth">sign in</a>
          with your myNortheastern username and password, or contact
          <a href="mailto:Library-Repository-Team@neu.edu">DRS Staff</a>.</p>
      </div>
    </noscript>
  </div>
  <script>
    function onTurnstileSuccess(token) {
      document.body.dataset.submitted = "1";
      document.getElementById('challenge-form').submit();
    }
    function onTurnstileError() {
      document.querySelector('.container').innerHTML +=
        '<p>Verification is currently unavailable. Please ' +
        '<a href="http://repository.library.northeastern.edu/users/auth/shibboleth">sign in</a> ' +
        'or contact <a href="mailto:Library-Repository-Team@neu.edu">DRS Staff</a>.</p>';
    }
    setTimeout(function () {
      if (!document.body.dataset.submitted) onTurnstileError();
    }, 15000);
  </script>
</body>
</html>
